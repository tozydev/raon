---
import type { GetStaticPaths } from "astro"
import { Image } from "astro:assets"
import { getCollection } from "astro:content"
import FormattedDate from "raon:components/FormattedDate.astro"
import { getLangPaths, useTranslations, type HasLang } from "raon:i18n"
import Base from "raon:layouts/Base.astro"

interface Props extends HasLang {}

export const getStaticPaths = (() => {
  return getLangPaths("posts", "/posts")
}) satisfies GetStaticPaths

const { lang } = Astro.props
const t = useTranslations(lang)

const posts = (await getCollection("posts"))
  .filter((post) => post.id.endsWith(`/index${lang}`))
  .map((post) => {
    const slug = post.id.split("/")[0]
    return { ...post, slug }
  })
  .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf())
---

<Base title={`${""} (${lang.toUpperCase()})`} description={"SITE_DESCRIPTION"}>
  <section class="mx-auto max-w-4xl">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        posts.map((post, index) => {
          const isFirst = index === 0
          return (
            <div class={isFirst ? "group md:col-span-2" : "group"}>
              <a
                href={lang === "vi" ? `/posts/${post.slug}/` : `/${lang}/posts/${post.slug}/`}
                class="block space-y-4"
              >
                {post.data.coverImage && (
                  <div class="overflow-hidden rounded-2xl shadow-md transition-shadow group-hover:shadow-xl">
                    <Image
                      width={isFirst ? 1020 : 720}
                      height={isFirst ? 510 : 360}
                      src={post.data.coverImage}
                      alt=""
                      class="h-55 w-full object-cover transition-transform duration-300 group-hover:scale-[1.01] md:h-95"
                    />
                  </div>
                )}
                <div class="space-y-2">
                  <div class="flex items-center gap-2 text-sm text-slate-500">
                    <FormattedDate date={post.data.publishedDate} />
                    {post.data.tags && post.data.tags.length > 0 && (
                      <>
                        <span class="text-slate-300">•</span>
                        <div class="flex gap-1.5">
                          {post.data.tags.slice(0, 2).map((tag) => (
                            <span class="text-xs font-semibold text-indigo-600">#{tag}</span>
                          ))}
                        </div>
                      </>
                    )}
                  </div>
                  <h4
                    class={`font-extrabold tracking-tight text-slate-900 transition-colors group-hover:text-indigo-600 ${isFirst ? "text-2xl md:text-3xl" : "text-xl"}`}
                  >
                    {post.data.title}
                  </h4>
                  <p class="line-clamp-2 text-sm leading-relaxed text-slate-600 md:text-base">
                    {post.data.description}
                  </p>
                </div>
              </a>
            </div>
          )
        })
      }
    </div>
  </section>
</Base>
