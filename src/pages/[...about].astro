---
import type { GetStaticPaths } from "astro"
import Contact from "raon:components/about/Contact.astro"
import Journey from "raon:components/about/Journey.astro"
import Profile from "raon:components/about/Profile.astro"
import Skills from "raon:components/about/Skills.astro"
import { getLangPaths, useTranslations, type HasLang } from "raon:i18n"
import Base from "raon:layouts/Base.astro"

interface Props extends HasLang {}

export const getStaticPaths = (() => {
  return getLangPaths("about", "/about")
}) satisfies GetStaticPaths

const { lang } = Astro.props
const t = useTranslations(lang)
---

<Base title={t("pages.about.title")} description={t("pages.about.description")}>
  <Profile />
  <Skills />
  <Journey />
  <Contact />
</Base>
