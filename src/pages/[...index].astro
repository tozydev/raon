---
import type { GetStaticPaths } from "astro"
import Hero from "raon:components/home/Hero.astro"
import RecentPosts from "raon:components/posts/RecentPosts.astro"
import FeaturedProjects from "raon:components/projects/FeaturedProjects.astro"
import { getLangPaths, useTranslations, type HasLang } from "raon:i18n"
import Base from "raon:layouts/Base.astro"

interface Props extends HasLang {}

export const getStaticPaths = (() => {
  return getLangPaths("index", "/")
}) satisfies GetStaticPaths

const { lang } = Astro.props
const t = useTranslations(lang)
---

<Base title={t("pages.home.title")} description={t("pages.home.description")}>
  <Hero />
  <FeaturedProjects />
  <RecentPosts />
</Base>
