---
import Hero from "@components/home/Hero.astro"
import RecentPosts from "@components/posts/RecentPosts.astro"
import FeaturedProjects from "@components/projects/FeaturedProjects.astro"
import Base from "@layouts/Base.astro"
import type { GetStaticPaths } from "astro"
import { getLangPaths, useTranslations, type HasLang } from "raon:i18n"

interface Props extends HasLang {}

export const getStaticPaths = (() => {
  return getLangPaths("index", "/")
}) satisfies GetStaticPaths

const { lang } = Astro.props
const t = useTranslations(lang)
---

<Base title={t("pages.home.title")} description={t("pages.home.description")}>
  <Hero />
  <FeaturedProjects />
  <RecentPosts />
</Base>
