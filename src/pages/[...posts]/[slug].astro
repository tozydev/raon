---
import { getCollection, render, type CollectionEntry } from "astro:content"
import { defaultLang, Languages, useTranslatedPath, type Language } from "raon:i18n"
import BlogPost from "raon:layouts/BlogPost.astro"

export async function getStaticPaths() {
  const posts = await getCollection("posts")
  const paths = posts.map((post) => {
    const parts = post.id.split("/")
    const slug = parts[0]
    const fileLang = parts[1] ? parts[1].replace("index", "") : "vi"
    const lang = Object.values(Languages).includes(fileLang as Language) ? fileLang : defaultLang

    const res = {
      params: { posts: useTranslatedPath(lang as Language)("/posts"), slug },
      props: post,
    }
    return res
  })
  console.log(
    "DEBUG: posts/[...slug] paths:",
    JSON.stringify(
      paths.map((p) => p.params),
      null,
      2,
    ),
  )
  return paths
}
type Props = CollectionEntry<"posts">

const post = Astro.props
const { Content } = await render(post)
---

<BlogPost {...post.data}>
  <Content />
</BlogPost>
