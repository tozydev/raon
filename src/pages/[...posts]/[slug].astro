---
import { BookOpen, Calendar, Heart } from "@lucide/astro"
import type { GetStaticPaths } from "astro"
import { Image } from "astro:assets"
import { render } from "astro:content"
import FormattedDate from "raon:components/FormattedDate.astro"
import { ROUTES } from "raon:consts"
import { getPosts, type Post } from "raon:content"
import { useTranslatedPath, useTranslations } from "raon:i18n"
import Base from "raon:layouts/Base.astro"

export const getStaticPaths = (async () => {
  return (await getPosts()).map((post) => {
    return {
      params: { posts: useTranslatedPath(post.lang)(ROUTES.posts), slug: post.slug },
      props: { post },
    }
  })
}) satisfies GetStaticPaths

export interface Props {
  post: Post
}

const { post } = Astro.props
const { Content, remarkPluginFrontmatter } = await render(post)

const t = useTranslations(post.lang)

const readTimeStr = t("pages.posts.readTime").replace(
  "{minutes}",
  remarkPluginFrontmatter.minutesRead,
)

// Get 3 post recommendations sorted by tag similarity
const allPosts = await getPosts({ lang: post.lang })
const currentSlug = post.slug
const currentTags = post.data.tags || []
const otherPosts = allPosts.filter((p) => p.slug !== currentSlug)

const recommendations = [...otherPosts]
  .sort((a, b) => {
    const aMatches = a.data.tags?.filter((t) => currentTags.includes(t)).length || 0
    const bMatches = b.data.tags?.filter((t) => currentTags.includes(t)).length || 0
    return bMatches - aMatches
  })
  .slice(0, 3)
---

<Base title={post.data.title} description={post.data.description} image={post.data.coverImage}>
  <div class="flex flex-col gap-6">
    <article class="island overflow-hidden">
      <div class="border-outline h-64 w-full overflow-hidden border-b sm:h-96">
        <Image
          src={post.data.coverImage}
          alt={post.data.title}
          fetchpriority="high"
          loading="eager"
          class="h-full w-full object-cover"
        />
      </div>

      <div class="flex flex-col gap-6 p-6 sm:p-10">
        <header class="flex flex-col gap-6">
          <div
            class="text-on-surface-variant flex flex-wrap items-center gap-3 text-sm font-semibold"
          >
            <div class="flex items-center gap-1.5">
              <Calendar class="size-4" />
              <FormattedDate date={post.data.publishedDate} />
            </div>
            <span>•</span>
            <div class="flex items-center gap-1.5">
              <BookOpen class="size-4" />
              <span>{readTimeStr}</span>
            </div>
          </div>
          <h1 class="text-brand font-heading text-4xl font-bold sm:text-5xl">
            {post.data.title}
          </h1>
        </header>

        <section class="prose prose-raon md:prose-lg max-w-none">
          <Content />
        </section>

        {
          post.data.tags.length > 0 && (
            <footer class="border-outline mt-4 flex flex-wrap gap-2 border-t pt-6">
              {post.data.tags.map((tag) => (
                <span class="badge badge-soft hover:text-brand hover:border-brand transition-colors">
                  #{tag}
                </span>
              ))}
            </footer>
          )
        }
      </div>
    </article>

    {
      /* Extract to component */
      recommendations.length > 0 && (
        <section class="mt-6 flex flex-col gap-6">
          <div class="flex items-center gap-2">
            <Heart class="text-brand size-5" />
            <h3 class="text-on-surface font-heading text-2xl font-bold">
              {t("pages.posts.recommendationsTitle")}
            </h3>
          </div>

          <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
            {recommendations.map((rec) => (
              <a
                href={rec.url}
                class="island island-interactive group decoration-none flex flex-col overflow-hidden"
              >
                {rec.data.coverImage && (
                  <div class="border-outline h-32 w-full overflow-hidden border-b">
                    <Image
                      src={rec.data.coverImage}
                      alt={rec.data.title}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-102"
                    />
                  </div>
                )}
                <div class="flex grow flex-col justify-between gap-2 p-4">
                  <h4 class="text-on-surface group-hover:text-brand line-clamp-2 text-sm leading-snug font-bold transition-colors">
                    {rec.data.title}
                  </h4>
                  <div class="text-on-surface-variant/60 text-[10px] font-semibold">
                    <FormattedDate date={rec.data.publishedDate} />
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>
</Base>
