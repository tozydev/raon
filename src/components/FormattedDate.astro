---
import { getLangFromUrl, Languages } from "raon:i18n"

interface Props {
  date: Date
}

const { date } = Astro.props

const lang = getLangFromUrl(Astro.url)
const locale = (function () {
  switch (lang) {
    case Languages.En:
      return "en-us"
    case Languages.Vi:
      return "vi-vn"
  }
})()
---

<time datetime={date.toISOString()}>
  {
    date.toLocaleDateString(locale, {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  }
</time>
