---
import { ExternalLink } from "@lucide/astro"
import GitHub from "raon:assets/github.svg"

// todo use content collection
export interface Project {
  title: string
  description: string
  tags: string[]
  github: string
  demo?: string
  coverImage?: string
}

interface Props {
  project: Project
}

const { project } = Astro.props
---

<div class="island flex flex-col justify-between overflow-hidden">
  {
    project.coverImage && (
      <div class="border-outline h-48 w-full overflow-hidden border-b">
        <img
          src={project.coverImage}
          alt={project.title}
          class="h-full w-full object-cover transition-transform duration-500 hover:scale-102"
        />
      </div>
    )
  }
  <div class="flex grow flex-col justify-between gap-4 p-6">
    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between">
        <h3 class="text-on-surface font-heading text-xl font-bold">
          {project.title}
        </h3>
        <div class="flex items-center gap-3">
          <a
            href={project.github}
            target="_blank"
            class="link link-variant"
            aria-label="GitHub Repository"
          >
            <GitHub class="size-5" />
          </a>
          {
            project.demo && (
              <a
                href={project.demo}
                target="_blank"
                class="link link-variant"
                aria-label="Live Demo"
              >
                <ExternalLink class="size-5" />
              </a>
            )
          }
        </div>
      </div>
      <p class="text-on-surface-variant text-sm leading-relaxed">
        {project.description}
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      {
        project.tags.map((tag) => (
          <span class="text-on-surface-variant bg-surface-variant border-outline rounded-lg border px-2.5 py-1 text-xs font-semibold">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</div>
