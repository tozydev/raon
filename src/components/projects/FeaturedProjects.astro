---
import { ArrowRight } from "@lucide/astro"
import { getCollection } from "astro:content"
import { ROUTES } from "raon:consts"
import { getLangFromUrl, useTranslatedPath, useTranslations } from "raon:i18n"
import ProjectCard from "./ProjectCard.astro"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)

const projects = (await getCollection("projects"))
  .filter((project) => project.data.featured)
  .slice(0, 3)
---

<section class="flex flex-col gap-6">
  <div class="flex w-full items-center justify-between">
    <div class="flex items-center gap-2">
      <h2 class="text-on-surface font-heading text-2xl font-bold">
        {t("pages.home.featuredProjects.title")}
      </h2>
    </div>
    <a
      href={translatePath(ROUTES.projects)}
      class="text-brand hover:text-on-surface flex cursor-pointer items-center gap-1 text-sm font-semibold transition-colors"
    >
      {t("common.buttons.viewMore")}
      <ArrowRight class="size-4" />
    </a>
  </div>

  <div class="grid grid-cols-1 gap-6">
    {projects.map((project) => <ProjectCard project={project} />)}
  </div>
</section>
