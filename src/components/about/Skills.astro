---
import { PROFILE } from "raon:consts"
import { getLangFromUrl, useTranslations } from "raon:i18n"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<section class="flex flex-col gap-6">
  <div class="flex items-center gap-2">
    <h2 class="text-on-surface font-heading text-2xl font-bold">{t("pages.about.skills.title")}</h2>
  </div>

  <div class="island p-6 sm:p-8">
    <div class="flex flex-wrap gap-2.5">
      {
        PROFILE.skills.map((skill) => (
          <span class="badge badge-lg badge-surface-variant text-xs sm:text-sm">{skill}</span>
        ))
      }
    </div>
  </div>
</section>
