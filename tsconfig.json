{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "astro.config.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strictNullChecks": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "raon:assets/*": ["./src/assets/*"],
      "raon:consts": ["./src/consts.ts"],
      "raon:components/*": ["./src/components/*"],
      "raon:i18n": ["./src/i18n/index.ts"],
      "raon:layouts/*": ["./src/layouts/*"],
      "raon:scripts/*": ["./src/scripts/*"]
    }
  }
}
